<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Font Requests</title>
</head>
<body>
  <h1>Font Requests</h1>
  <table border="1">
    <thead>
      <tr>
        <th>Hash Index</th>
        <th>Original Hash</th>
        <th>Font Type ID</th>
        <th>Weight</th>
        <th>User ID</th>
        <th>Use Count</th>
      </tr>
    </thead>
    <tbody>
      <% data.forEach(function(row) { %>
        <tr>
          <td><%= row.hash_index %></td>
          <td><%= row.original_hash %></td>
          <td><%= row.font_type_id %></td>
          <td><%= row.weight %></td>
          <td><%= row.creat_dpmain %></td>
          <td><%= row.use_count %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</body>
</html>
