{
  "name": "emfont-monorepo",
  "private": true,
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "scripts": {
    "build": "pnpm run build:web && pnpm run build:docs && pnpm run build:mcp",
    "build:docs": "pnpm --filter ./apps/docs run build",
    "build:mcp": "pnpm --filter ./apps/mcp run build",
    "build:web": "pnpm --filter ./apps/web run build",
    "check:web": "pnpm --filter ./apps/web run check",
    "db:migrate": "pnpm --filter ./apps/server run db:migrate",
    "dev": "pnpm run dev:server",
    "dev:docs": "pnpm --filter ./apps/docs run dev",
    "dev:server": "pnpm --filter ./apps/server run dev",
    "dev:web": "pnpm --filter ./apps/web run dev",
    "format": "pnpm --filter ./apps/server run format",
    "start": "pnpm run start:server",
    "start:docs": "pnpm --filter ./apps/docs run start",
    "start:mcp": "pnpm --filter ./apps/mcp run start",
    "start:server": "pnpm --filter ./apps/server run start",
    "start:server:migrate": "pnpm --filter ./apps/server run start:with-migrate",
    "start:web": "pnpm --filter ./apps/web run start",
    "test:mcp": "pnpm --filter ./apps/mcp run test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@datadog/pprof",
      "esbuild",
      "sharp",
      "ttf2woff2",
      "unrs-resolver"
    ]
  }
}
