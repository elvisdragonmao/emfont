{
	"name": "emfont",
	"version": "1.0.0",
	"description": "A free and open-source Chinese web font service",
	"keywords": [],
	"repository": "https://github.com/emfont/emfont.git",
	"license": "Apache-2.0",
	"author": "Elvis Mao <info@elvismao.com>",
	"type": "module",
	"main": "src/app.js",
	"scripts": {
		"db:migrate": "node ./scripts/migrate.js",
		"dev": "nodemon src/app.js --ignore public/*",
		"format": "prettier --write .",
		"prepare": "sh -c 'command -v git >/dev/null 2>&1 && [ -d .git ] && git config core.hooksPath .githooks || exit 0'",
		"start": "node src/app.js",
		"start:with-migrate": "pnpm run db:migrate && pnpm run start",
		"test": "echo \"Error: no test specified\" && exit 1",
		"test_f": "node src/r2.js"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.850.0",
		"@fastify/cookie": "^11.0.2",
		"@fastify/cors": "^11.0.1",
		"@fastify/static": "^8.2.0",
		"@pyroscope/nodejs": "^0.4.10",
		"@types/subset-font": "^2.3.0",
		"axios": "^1.11.0",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.5",
		"dotenv": "^16.6.1",
		"fastify": "^5.7.4",
		"fastify-metrics": "^12.1.0",
		"fontkit": "^2.0.4",
		"ioredis": "^5.6.1",
		"pg": "^8.16.3",
		"postgrator": "^8.0.0",
		"prom-client": "^15.1.3",
		"subset-font": "^2.4.0",
		"terser": "^5.43.1"
	},
	"devDependencies": {
		"nodemon": "^3.1.10",
		"pino-pretty": "^13.1.3",
		"prettier": "^3.8.3",
		"prettier-plugin-organize-imports": "^4.3.0",
		"prettier-plugin-packagejson": "^3.0.2"
	},
	"packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
	"pnpm": {
		"onlyBuiltDependencies": [
			"ttf2woff2"
		]
	}
}
